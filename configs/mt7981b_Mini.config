# ==============================================
# OpenWrt MT7981B 编译配置文件（mt7981b_Mini.config）
# 配置说明：适配MT7981B处理器路由器，集成常用插件
# 请根据你的具体路由器型号修改设备配置！
# ==============================================

# -------------------------- 目标平台配置 --------------------------
# 启用Mediatek架构（MT7981B属于Mediatek filogic系列）
CONFIG_TARGET_mediatek=y
# 启用filogic子架构（MT7981B/MT7986等Filogic芯片）
CONFIG_TARGET_mediatek_filogic=y

# Oray X1 Pro（硬件与Cudy TR3000 v1相同，使用相同配置）
CONFIG_TARGET_mediatek_filogic_DEVICE_cudy_tr3000-v1=y

# -------------------------- 固件分区配置 --------------------------
# 内核分区大小：8MB（ARM路由器通常比x86小）
CONFIG_TARGET_KERNEL_PARTSIZE=8
# 根文件系统分区大小：256MB（根据实际插件数量调整）
CONFIG_TARGET_ROOTFS_PARTSIZE=256

# -------------------------- 固件格式配置 --------------------------
# 启用SquashFS根文件系统（OpenWrt主流格式）
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# 关闭EXT4根文件系统
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
# 启用GPT分区表支持（现代ARM路由器）
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# 固件压缩格式：GZIP
CONFIG_TARGET_IMAGES_GZIP=y

# -------------------------- 核心应用插件 --------------------------
# 1. 广告屏蔽：Adbyby Plus
CONFIG_PACKAGE_adbyby-plus=y
CONFIG_PACKAGE_luci-app-adbyby-plus=y

# 2. 广告过滤/DNS解析：AdGuardHome
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y

# 3. 应用过滤：Openlist
CONFIG_PACKAGE_openlist=y
CONFIG_PACKAGE_luci-app-openlist=y

# 4. 主题配置：Argon主题设置
CONFIG_PACKAGE_luci-app-argon-config=y

# 5. ARP绑定：防ARP欺骗
CONFIG_PACKAGE_arpbind=y
CONFIG_PACKAGE_luci-app-arpbind=y

# 6. 自动重启：定时重启系统
CONFIG_PACKAGE_autoreboot=y
CONFIG_PACKAGE_luci-app-autoreboot=y

# 7. DDNS动态域名
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y

# 8. 磁盘管理：分区/挂载管理
CONFIG_PACKAGE_diskman=y
CONFIG_PACKAGE_luci-app-diskman=y

# 9. 文件传输：WEB文件上传/下载
CONFIG_PACKAGE_filetransfer=y
CONFIG_PACKAGE_luci-app-filetransfer=y

# 10. 防火墙
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_luci-app-firewall=y

# 11. 系统监控：Netdata
# CONFIG_PACKAGE_netdata=y
# CONFIG_PACKAGE_luci-app-netdata=y

# 12. 流量统计：NLBWmon
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-nlbwmon=y

# 13. 在线用户：查看在线设备
CONFIG_PACKAGE_onliner=y
CONFIG_PACKAGE_luci-app-onliner=y

# 14. 网络代理：OpenClash
CONFIG_PACKAGE_openclash=y
CONFIG_PACKAGE_luci-app-openclash=y

# 15. 广告过滤：iKoolProxy
CONFIG_PACKAGE_ikoolproxy=y
CONFIG_PACKAGE_luci-app-ikoolproxy=y

# 16. 网络代理：PassWall2
CONFIG_PACKAGE_passwall2=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-app-passwall2_Iptables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall2_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_brook=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Brook=y
CONFIG_PACKAGE_hysteria=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_IPv6_Nat=y
CONFIG_PACKAGE_naiveproxy=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_NaiveProxy=y
CONFIG_PACKAGE_shadowsocks-libev-server=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Libev_Server=y
CONFIG_PACKAGE_shadowsocks-rust-client=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client=y
CONFIG_PACKAGE_shadowsocks-rust-server=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Server=y
CONFIG_PACKAGE_shadowsocksr-libev-server=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ShadowsocksR_Libev_Server=y
CONFIG_PACKAGE_tuic-client=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_tuic_client=y

# 17. 系统关机：WEB关机/重启
CONFIG_PACKAGE_luci-app-poweroff=y

# 18. 网络代理：V2Ray服务端
CONFIG_PACKAGE_v2ray-server=y
CONFIG_PACKAGE_luci-app-v2ray-server=y

# 19. 网络共享：Samba4
CONFIG_PACKAGE_samba4=y
CONFIG_PACKAGE_luci-app-samba4=y

# 20. WEB终端：TTYD
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y

# 21. 组播转单播：UDProxy
CONFIG_PACKAGE_udpxy=y
CONFIG_PACKAGE_luci-app-udpxy=y

# 22. 网络加速：TurboACC
CONFIG_PACKAGE_turboacc=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_dnsforwarder=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_DNSFORWARDER=y
CONFIG_PACKAGE_dnsproxy=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_DNSPROXY=y

# 23. 解锁音乐：UnblockMusic
CONFIG_PACKAGE_unblockmusic=y
CONFIG_PACKAGE_luci-app-unblockmusic=y

# 24. UPnP：自动端口映射
CONFIG_PACKAGE_upnp=y
CONFIG_PACKAGE_luci-app-upnp=y

# 25. 网络唤醒：WOL
CONFIG_PACKAGE_wol=y
CONFIG_PACKAGE_luci-app-wol=y

# 26. VPN：OpenVPN
CONFIG_PACKAGE_openvpn=y
CONFIG_PACKAGE_luci-app-openvpn=y

# 27. 网络代理：VSSR
CONFIG_PACKAGE_vssr=y
CONFIG_PACKAGE_luci-app-vssr=m
CONFIG_PACKAGE_v2ray-plugin=y
CONFIG_PACKAGE_luci-app-vssr_INCLUDE_V2ray_plugin=y
CONFIG_PACKAGE_xray=y
CONFIG_PACKAGE_luci-app-vssr_INCLUDE_Xray=y
CONFIG_PACKAGE_trojan=y
CONFIG_PACKAGE_luci-app-vssr_INCLUDE_Trojan=y
CONFIG_PACKAGE_kcptun=y
CONFIG_PACKAGE_luci-app-vssr_INCLUDE_Kcptun=y
CONFIG_PACKAGE_luci-app-vssr_INCLUDE_ShadowsocksR_Server=y

# -------------------------- VPN专项插件 --------------------------
# 1. ZeroTier：虚拟局域网
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y

# 2. PPTP VPN
CONFIG_PACKAGE_pptpd=y
CONFIG_PACKAGE_luci-app-pptp-server=y
CONFIG_PACKAGE_luci-app-pptpd=y

# 3. IPSEC VPN
CONFIG_PACKAGE_strongswan=y
CONFIG_PACKAGE_strongswan-ipsecmgr=y
CONFIG_PACKAGE_luci-app-ipsec-server=y
CONFIG_PACKAGE_luci-app-ipsec-vpnd=y
CONFIG_PACKAGE_luci-app-ipsec-vpnserver-manyusers=y

# 4. OpenVPN服务端
CONFIG_PACKAGE_openvpn-server=y
CONFIG_PACKAGE_luci-app-openvpn-server=y

# 5. SoftEther VPN
CONFIG_PACKAGE_softethervpn=y
CONFIG_PACKAGE_luci-app-softethervpn=y

# -------------------------- 主题配置 --------------------------
# 1. Argon主题
CONFIG_PACKAGE_luci-theme-argon=y
# 2. Design主题
CONFIG_PACKAGE_luci-theme-design=y

# -------------------------- 基础工具包 --------------------------
CONFIG_PACKAGE_autosamba=y
CONFIG_PACKAGE_ddns-scripts_cloudflare.com-v4=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_nano-plus=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_snmpd=y
CONFIG_PACKAGE_vim-fuller=y
CONFIG_PACKAGE_zsh=y

# -------------------------- 内核加速模块 --------------------------
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y

# -------------------------- IPv6支持 --------------------------
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_ip6tables-extra=y
CONFIG_PACKAGE_ip6tables-mod-nat=y

# -------------------------- 禁用有问题的包 --------------------------
# 这些包在编译时会报错，已禁用
# CONFIG_PACKAGE_lxc is not set
# CONFIG_PACKAGE_onionshare-cli is not set
