# ===================== 目标平台 =====================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ===================== 分区与镜像 =====================
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=800

# 镜像类型
# CONFIG_GRUB_CONSOLE is not set
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y
# CONFIG_VMDK_IMAGES is not set

# ImageBuilder
CONFIG_IB=y
CONFIG_IB_STANDALONE=y

# ===================== 基本路由功能 =====================
CONFIG_PACKAGE_luci-app-firewall=y       # 防火墙（核心）
CONFIG_PACKAGE_luci-app-uhttpd=y         # Web管理界面（LuCI依赖）

# ===================== 科学上网 =====================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-app-passwall2_Iptables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall2_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_tuic_client=y

# ===================== VPN 服务 =====================
CONFIG_PACKAGE_luci-app-openvpn-server=y         # OpenVPN 服务端
CONFIG_PACKAGE_luci-app-ipsec-server=y           # IPsec VPN 服务端
CONFIG_PACKAGE_luci-app-ipsec-vpnd=y             # IPsec VPN 守护进程
CONFIG_PACKAGE_luci-app-ipsec-vpnserver-manyusers=y # IPsec 多用户管理
CONFIG_PACKAGE_luci-app-pptp-server=y            # PPTP VPN 服务端
CONFIG_PACKAGE_luci-app-softethervpn=y           # SoftEther VPN
CONFIG_PACKAGE_luci-app-wireguard=y              # WireGuard VPN
CONFIG_PACKAGE_luci-app-zerotier=y               # ZeroTier 虚拟局域网
CONFIG_PACKAGE_luci-app-n2n=y                    # N2N 组网
CONFIG_PACKAGE_luci-app-frpc=y                   # FRP 客户端
CONFIG_PACKAGE_luci-app-frps=y                   # FRP 服务端
CONFIG_PACKAGE_strongswan=y                      # StrongSwan IPsec

# ===================== 应用服务 =====================
CONFIG_PACKAGE_luci-app-adguardhome=y            # AdGuardHome 广告过滤
CONFIG_PACKAGE_luci-app-udpxy=y                  # UDP组播转HTTP（IPTV）
CONFIG_PACKAGE_luci-app-nps=y                    # NPS 内网穿透
CONFIG_PACKAGE_luci-app-store=y                  # iStore 软件商店
CONFIG_PACKAGE_luci-i18n-store-zh-cn=y           # iStore 中文语言包
CONFIG_PACKAGE_luci-app-ddns=y                   # 动态DNS
CONFIG_PACKAGE_luci-app-upnp=y                   # UPnP 自动端口映射

# ===================== 主题与语言 =====================
CONFIG_PACKAGE_luci-theme-argon=y                # Argon 主题
CONFIG_PACKAGE_luci-theme-aurora=y               # Aurora 主题
CONFIG_PACKAGE_luci-app-aurora-config=y          # Aurora 主题配置
CONFIG_PACKAGE_luci-app-argon-config=y           # Argon 主题配置
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y            # LuCI 中文语言包
